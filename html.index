    <div class="record-section">
      <div class="record-section-title">Key Stats</div>
      <div class="record-row"><div class="record-name">Peak Membership</div><div class="record-val">250+</div></div>
      <div class="record-row"><div class="record-name">Current Membership</div><div class="record-val">241</div></div>
